
    digraph G {
        graph [splines=true];
        node [fontname="Arial"];
        edge [penwidth=1.5];
    "__start__" [label="__start__", shape=ellipse, style=filled, fillcolor=lightblue, width=0.5, height=0.3];"__end__" [label="__end__", shape=ellipse, style=filled, fillcolor=lightblue, width=0.5, height=0.3];"Research Agent" [label="Research Agent", shape=box, style=filled, fillcolor=lightyellow, width=1.5, height=0.8];"Research Tools" [label="Research Tools", shape=box, style=filled, fillcolor=lightgrey, width=1, height=0.5];"Thinking Agent" [label="Thinking Agent", shape=box, style="filled,rounded", fillcolor=lightyellow, width=1.5, height=0.8];"sequential-thinking" [label="sequential-thinking", shape=box, style=filled, fillcolor=lightgrey, width=1, height=0.5];"Filesystem Agent" [label="Filesystem Agent", shape=box, style="filled,rounded", fillcolor=lightyellow, width=1.5, height=0.8];"filesystem" [label="filesystem", shape=box, style=filled, fillcolor=lightgrey, width=1, height=0.5];"__start__" -> "Research Agent";
        "Research Agent" -> "Research Tools" [style=dashed, penwidth=1.5];
        "Research Tools" -> "Research Agent" [style=dashed, penwidth=1.5];
            "Research Agent" -> "Thinking Agent";
        "Thinking Agent" -> "sequential-thinking" [style=dashed, penwidth=1.5];
        "sequential-thinking" -> "Thinking Agent" [style=dashed, penwidth=1.5];
            "Thinking Agent" -> "Filesystem Agent";
        "Filesystem Agent" -> "filesystem" [style=dashed, penwidth=1.5];
        "filesystem" -> "Filesystem Agent" [style=dashed, penwidth=1.5];"Filesystem Agent" -> "__end__";}
